# Python virtual environment
venv/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Environment variables — contains secrets
.env

# AWS credentials — never commit
.aws/

# Checkpoints — large Spark recovery files
checkpoints/

# Temporary / scratch data
data/
tmp/
temp/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Terraform state & lock — managed separately, may contain sensitive output
.terraform/
terraform/.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Large / generated files
jars/
lambda/*.zip
*.zip

# Generated graphs — regenerated on demand via experiments/generate_graphs.py
experiments/graphs/*.png

# Node modules
node_modules/

# Docker
.docker/

# Claude IDE config
.claude.json
.claude/

# Minikube local state
.minikube/
